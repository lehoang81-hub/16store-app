# ─────────────────────────────────────────────────────────────
# 16STORE — Environment variables
# Copy this file to .env.local and fill in real values
# ─────────────────────────────────────────────────────────────

# ─── SUPABASE (Project Settings → API) ─────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_PROJECT_ID=your-project-id

# ─── TELEGRAM BOT (Phase 2) ────────────────────────────────
# Lấy từ @BotFather, gõ /newbot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string-here

# ─── GEMINI AI (Phase 3) ───────────────────────────────────
# Lấy tại https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── PAYMENT (Phase 3) ─────────────────────────────────────
# VietQR — không cần API key, dùng img.vietqr.io
# Mã ngân hàng BIN: tra tại https://api.vietqr.io/v2/banks
BANK_BIN=970422
# 970422 = MBBank, 970418 = BIDV, 970436 = Vietcombank, 970407 = Techcombank
BANK_ACCOUNT=0123456789
BANK_NAME=NGUYEN VAN A

# PayOS (Phase 3 — chưa cần ngay, dùng mock)
# Đăng ký tại https://payos.vn
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# Bật mock = true để test không cần PayOS thật
USE_PAYMENT_MOCK=true

# ─── APP URL ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
